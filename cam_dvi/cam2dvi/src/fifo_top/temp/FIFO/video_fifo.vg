`pragma protect end_protected
module video_fifo (
  Data,
  Reset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Rnum,
  Q,
  Empty,
  Full
)
;
input [15:0] Data;
input Reset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [12:0] Rnum;
output [15:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.video_fifo  fifo_inst (
    .Reset(Reset),
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[15:0]),
    .Empty(Empty),
    .Full(Full),
    .Rnum(Rnum[12:0]),
    .Q(Q[15:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* video_fifo */
